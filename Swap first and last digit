import java.util.*;
public class Main{
    public static void main(String[] args){
        Scanner obj=new Scanner(System.in);
        int n=obj.nextInt();
        int count=0;
        int temp=n;
        while(temp!=0){
            temp=temp/10;
            count++;
        }
        int forml=(int)Math.pow(10,count-1);
        int l=n%10;
        int f=n/forml;
        int m=(n%forml)/10;
        int res=(l*(int)Math.pow(10,count-2)+m)*10+f;
        System.out.println(res);
        
    }
}
